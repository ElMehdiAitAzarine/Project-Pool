# Django Core Configuration
DJANGO_SETTINGS_MODULE=core_project.settings_prod
DJANGO_SECRET_KEY=replace-with-a-very-long-random-string-here
DEBUG=False

# Domains (Comma separated without spaces)
ALLOWED_HOSTS=api.yourdomain.com,yourdomain.com
CORS_ALLOWED_ORIGINS=https://your-frontend.com,https://www.your-frontend.com
FRONTEND_URL=https://your-frontend.com

# MySQL Database (o2switch cPanel)
# Note: Prefixes (like 'username_') are mandatory on o2switch
DB_NAME=username_cueclub_db
DB_USER=username_cueclub_user
DB_PASSWORD=your_mysql_password_here
DB_HOST=127.0.0.1
DB_PORT=3306

# HTTPS (Set to True once your SSL certificate is active)
SECURE_SSL_REDIRECT=True
